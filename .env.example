# Local Docker compose settings. Copy this file to .env for local development.

FRONTEND_PORT=3000
BACKEND_PORT=8080

# Vite build-time values for the nginx-served frontend image.
VITE_BACKEND_BASE_URL=http://localhost:8080
VITE_STREAM_BASE_URL=http://localhost:18000
VITE_STREAM_MODE=webrtc
VITE_HLS_BASE_URL=http://localhost:8888
VITE_WEBRTC_BASE_URL=http://localhost:8889
VITE_STREAM_FALLBACK_ENABLED=true
VITE_CAMERA_1_STREAM_URL=http://localhost:8010/stream
VITE_CAMERA_2_STREAM_URL=http://localhost:8011/stream
VITE_CAMERA_3_STREAM_URL=http://localhost:8012/stream
VITE_CAMERA_4_STREAM_URL=http://localhost:8013/stream

# Local PostgreSQL for the Spring Boot backend.
POSTGRES_PORT=5432
POSTGRES_DB=strange_safety
POSTGRES_USER=strange
POSTGRES_PASSWORD=strange_local_password
DB_URL=jdbc:postgresql://postgres:5432/strange_safety
DB_USERNAME=strange
DB_PASSWORD=strange_local_password
JPA_DDL_AUTO=update

# Local MQTT message broker.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_BROKER_URL=tcp://mosquitto:1883
MQTT_TOPIC=safety/events
MQTT_CLIENT_ID=safety-backend-local

# Local-only secrets. Override these in a private .env and never commit real production values.
JWT_SECRET=local-development-jwt-secret-change-before-shared-use-32bytes
AES_SECRET_KEY=StrangeSafetyKey
AES_IV=StrangeSafetyIv!
WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173

# Optional legacy Redis settings. Redis starts only with: docker compose --profile redis up -d
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
